# Kanshi - Wayland display profile manager
# Run 'hyprctl monitors' to detect your monitors and get profile suggestions
#
# Identifier format: "Make Model *" (wildcard for serial)
# Find yours with: hyprctl monitors -j | jq '.[] | "\(.make) \(.model) \(.serial)"'

# Example: External monitor (disable laptop)
profile external {
    output eDP-1 disable
    output "Dell Inc. DELL S2721DGF *" mode 2560x1440@143.91Hz position 0,0
}

# Laptop only (no external)
profile laptop-only {
    output eDP-1 enable scale 1.8
}

profile single {
    # Right monitor only (left one is switched to the macOS input).
    output "Dell Inc. DELL S2721DGF 477KT83" enable mode 2560x1440@165.08Hz position 0,0
}

profile dual {
    # Anchored by serial so the layout is stable regardless of which DP port is used.
    # 9QJZP83 = physical LEFT (primary, at 0,0); 477KT83 = physical RIGHT
    output "Dell Inc. DELL S2721DGF 9QJZP83" enable mode 2560x1440@165.08Hz position 0,0
    output "Dell Inc. DELL S2721DGF 477KT83" enable mode 2560x1440@165.08Hz position 2560,0
}